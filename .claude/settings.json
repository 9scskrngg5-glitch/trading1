{
  "llm": {
    "provider": "openrouter",
    "apiKey": "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",
    "baseUrl": "https://openrouter.ai/api/v1",
    "model": "google/gemma-2-9b-it:free",
    "fallbackModel": "nvidia/llama-3.1-nemotron-70b-instruct:free"
  },
  "completion": {
    "temperature": 0.7
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Write|Edit|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-edit.mjs \"${tool.params.file_path}\""
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-bash.mjs \"${tool.params.command}\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Write|Edit|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-edit.mjs \"${tool.params.file_path}\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/notify.mjs \"${notification.message}\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-start.mjs"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-end.mjs"
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["claude-flow"],
  "integrations": {
    "hermes-agent": {
      "enabled": true,
      "hooksDir": ".claude/hooks/hermes"
    },
    "multica": {
      "enabled": false,
      "serverUrl": "${MULTICA_SERVER_URL}"
    }
  }
}
