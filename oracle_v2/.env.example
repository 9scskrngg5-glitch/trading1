# ─── ORACLE v2 — Variables d'environnement ───────────────────────────────────
# Copier ce fichier en .env et remplir les valeurs
# NEVER commit .env

# ── Mode ──────────────────────────────────────────────────────────────────────
ORACLE_MODE=paper          # paper | live

# ── LLM — Narrator (priorité: Free-GPT4 → OpenRouter → Anthropic → template) ─
FREE_GPT4_URL=http://127.0.0.1:5500     # Optionnel — serveur local Free-GPT4
OPENROUTER_API_KEY=                      # hermes-agent OpenRouter (modèles gratuits dispo)
ANTHROPIC_API_KEY=                       # Claude Haiku (optionnel)

# ── Binance ───────────────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET=
BINANCE_TESTNET=true                     # true = testnet, false = live

# ── Capital.com ───────────────────────────────────────────────────────────────
CAPITAL_API_KEY=
CAPITAL_PASSWORD=

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Polymarket CLOB — Trading actif (optionnel) ───────────────────────────────
#
# Étapes pour obtenir vos clés :
#   1. Connectez-vous sur https://polymarket.com
#   2. Menu ≡ → Paramètres → API Keys → Créer une clé
#   3. Copiez API Key, Secret, et Passphrase ci-dessous
#
# POLYMARKET_PRIVATE_KEY : Clé privée de votre wallet Polygon (hexadécimal, 0x…)
#   ⚠ Ne partagez JAMAIS cette clé — elle contrôle vos fonds
#   Trouvez-la dans MetaMask → Paramètres → Sécurité → Exporter la clé privée
#
# POLYMARKET_PROXY_WALLET : Adresse du proxy wallet Polymarket (optionnel)
#   Visible sur le site Polymarket dans les paramètres de trading
#
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PROXY_WALLET=

# ── multica-ai (optionnel — issue tracking externe) ───────────────────────────
MULTICA_SERVER_URL=
MULTICA_WORKSPACE_ID=
